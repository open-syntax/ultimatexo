    "@react-types/shared": "3.33.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "2.1.1",
    "framer-motion": "12.38.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.13.2",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.2.2",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
